# ==============================================
# MiroFish + OpenZep 部署配置
# ==============================================
# 使用方法：复制此文件为 .env 并填写配置值
# cp .env.example .env && vim .env

# ==============================================
# LLM API 配置（必需）
# ==============================================

# 阿里百炼 API Key（从 https://bailian.console.aliyun.com/ 获取）
LLM_API_KEY=your_aliyun_api_key_here

# API 基础 URL（阿里云通义千问）
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 使用的模型名称
LLM_MODEL_NAME=qwen-plus
LLM_MODEL=qwen-plus
LLM_SMALL_MODEL=qwen-plus

# ==============================================
# 加速 LLM 配置（可选）
# ==============================================
# 如果使用其他 LLM 服务加速，填写以下配置
# 如不使用，保持为空即可

LLM_BOOST_API_KEY=
LLM_BOOST_BASE_URL=
LLM_BOOST_MODEL_NAME=

# ==============================================
# Embedder 配置（OpenZep 使用）
# ==============================================

# 向量嵌入模型（使用阿里云）
EMBEDDER_MODEL=text-embedding-v3
EMBEDDER_API_KEY=${LLM_API_KEY}
EMBEDDER_BASE_URL=${LLM_BASE_URL}

# ==============================================
# OpenZep 配置
# ==============================================

# OpenZep API Key（自定义一个用于内部服务的密钥）
OPENZEP_API_KEY=your_openzep_api_key_here

# ==============================================
# Neo4j 配置
# ==============================================

# Neo4j 数据库密码（请修改为强密码）
NEO4J_PASSWORD=password123

# ==============================================
# 部署配置（可选修改）
# ==============================================

# GitHub 用户名（用于拉取镜像）
GITHUB_USER=slashinchi

# 镜像标签
IMAGE_TAG=arm64

# 服务端口（如需修改）
# FRONTEND_PORT=3000
# BACKEND_PORT=5001
# OPENZEP_PORT=8000
# NEO4J_HTTP_PORT=7474
# NEO4J_BOLT_PORT=7687